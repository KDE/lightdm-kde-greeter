#: connectionsmodel.cpp:146
#, kde-format
msgid "VPN connection deactivated."
msgstr "Nie je spojenie"

#: connectionsmodel.cpp:148
#, kde-format
msgid ""
"VPN connection was deactivated because the device it was using was "
"disconnected."
msgstr ""
"VPN pripojenie bolo deaktivované, pretože zariadenie, ktoré používalo, bolo "
"odpojené."

#: connectionsmodel.cpp:150
#, kde-format
msgid "The service providing the VPN connection was stopped."
msgstr "Služba poskytujúca VPN pripojenie bola zastavená."

#: connectionsmodel.cpp:152
#, kde-format
msgid "The IP config of the VPN connection was invalid."
msgstr "Konfigurácia IP VPN pripojenia bola neplatná."

#: connectionsmodel.cpp:154
#, kde-format
msgid "The connection attempt to the VPN service timed out."
msgstr "Pokus o pripojenie k službe VPN vypršalo."

#: connectionsmodel.cpp:156
#, kde-format
msgid ""
"A timeout occurred while starting the service providing the VPN connection."
msgstr ""
"Pri spúšťaní služby poskytujúcej VPN pripojenie nastalo prekročenie časového "
"limitu."

#: connectionsmodel.cpp:158
#, kde-format
msgid "Starting the service providing the VPN connection failed."
msgstr "Spustenie služby poskytujúcej VPN pripojenie zlyhalo."

#: connectionsmodel.cpp:160
#, kde-format
msgid "Necessary secrets for the VPN connection were not provided."
msgstr "Potrebné tajné údaje pre VPN pripojenie neboli poskytnuté."

#: connectionsmodel.cpp:162
#, kde-format
msgid "Authentication to the VPN server failed."
msgstr "Overenie pre VPN server zlyhalo."

#: connectionsmodel.cpp:164
#, kde-format
msgid "The connection was deleted."
msgstr "Pripojenie bolo odstránené."

#: connectionsmodel.cpp:580
#, kde-format
msgid "No connection"
msgstr "Nie je spojenie"

