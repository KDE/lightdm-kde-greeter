#: config.qml:37
#, kde-format
msgid "Background image:"
msgstr "Obrázok pozadia:"

#: NetworkWidget.qml:24
#, kde-format
msgid "The connection will be active only on the login screen."
msgstr "Pripojenie bude aktívne iba na prihlasovacej obrazovke."

#: NetworkWidget.qml:61
#, kde-format
msgid "Disconnect from %1 ?"
msgstr "Odpojiť sa od %1?"

#: NetworkWidget.qml:64
#, kde-format
msgid "Abort connecting to %1 ?"
msgstr "Prerušiť pripájanie k %1?"

#: NetworkWidget.qml:68
#, kde-format
msgid "Connect to %1 ?"
msgstr "Pripojiť k %1?"

#: NetworkWidget.qml:72
#, kde-format
msgid "Connect to an insecure access point %1 ?"
msgstr "Pripojiť sa k nezabezpečenému prístupovému bodu %1?"

#: NetworkWidget.qml:77
#, kde-format
msgid "Enter the password to connect to %1"
msgstr "Zadajte heslo na pripojenie k %1"

#: NetworkWidget.qml:82
#, kde-format
msgid "Enter login and password to connect to %1"
msgstr "Zadajte prihlasovacie meno a heslo na pripojenie k %1"

#: NetworkWidget.qml:86 NetworkWidget.qml:92
#, kde-format
msgid "%1: Connection error, try again."
msgstr "%1: Chyba pripojenia, skúste znova."

#: NetworkWidget.qml:97
#, kde-format
msgid "Provide the secrets to connect to %1:"
msgstr "Zlyhalo pripojenie k %1"

#: NetworkWidget.qml:101
#, kde-format
msgid "The security protocol is not supported for %1"
msgstr "Bezpečnostný protokol nie je podporovaný pre %1"

#: NetworkWidget.qml:104 NetworkWidget.qml:108
#, kde-format
msgid "Failed to connect to %1"
msgstr "Zlyhalo pripojenie k %1"

#: NetworkWidget.qml:112
#, kde-format
msgid "Error: Can't find access point %1"
msgstr "Chyba: Can't find access point %1"

#: NetworkWidget.qml:440
#, kde-format
msgid "Login"
msgstr "Prihlásenie"

#: NetworkWidget.qml:455
#, kde-format
msgid "Password"
msgstr "Heslo"

#: NetworkWidget.qml:507
#, kde-format
msgid "Disable wireless"
msgstr "Zakázať bezdrôtové pripojenie"

#: NetworkWidget.qml:507
#, kde-format
msgid "Enable wireless"
msgstr "Povoliť bezdrôtové pripojenie"

#: NetworkWidget.qml:508 NetworkWidget.qml:549
#, kde-format
msgid "Action prohibited"
msgstr "Akcia zakázaná"

#: NetworkWidget.qml:548
#, kde-format
msgid "Disable networking"
msgstr "Zakázať sieť"

#: NetworkWidget.qml:548
#, kde-format
msgid "Enable networking"
msgstr "Povoliť sieť"

#: OtherScreen.qml:27
#, kde-format
msgid "Press %1 to change the primary screen"
msgstr "Stlačte %1 na zmenu primárnej obrazovky"

#: PrimaryScreen.qml:56
#, kde-format
msgid "A fallback version of the login screen is running"
msgstr "Je spustená záložná verzia prihlasovacej obrazovky"

#: PrimaryScreen.qml:86
#, kde-format
msgid "Login failed"
msgstr "Prihlásenie zlyhalo"

#: PrimaryScreen.qml:538
#, kde-format
msgid "Caps Lock is on"
msgstr "Funkcia Caps Lock je zapnutá"

#: PrimaryScreen.qml:541
#, kde-format
msgid "Num Lock is on"
msgstr "Num Lock je zapnutý"

#: PrimaryScreen.qml:544
#, kde-format
msgid "Caps Lock and Num Lock is on"
msgstr "Caps Lock a Num Lock sú zapnuté"

#: PrimaryScreen.qml:557
#, kde-format
msgid "Log in"
msgstr "Prihlásenie"

#: PrimaryScreen.qml:576
#, kde-format
msgid "Log in as another user"
msgstr "Prihlásiť sa ako iný používateľ"

#: PrimaryScreen.qml:769
#, kde-format
msgid "Keyboard layout"
msgstr "Rozloženie klávesnice"

#: PrimaryScreen.qml:814
#, kde-format
msgid "Desktop session"
msgstr "Sedenie plochy"

#: PrimaryScreen.qml:841
#, kde-format
msgid "Suspend"
msgstr "Uspať"

#: PrimaryScreen.qml:853
#, kde-format
msgid "Hibernate"
msgstr "Hibernovať"

#: PrimaryScreen.qml:866
#, kde-format
msgid "Restart"
msgstr "Reštart"

#: PrimaryScreen.qml:878
#, kde-format
msgid "Shutdown"
msgstr "Vypnutie"

#: PrimaryScreen.qml:908
#, kde-format
msgctxt "Button to show/hide virtual keyboard"
msgid "Virtual Keyboard"
msgstr "Virtuálna klávesnica"
